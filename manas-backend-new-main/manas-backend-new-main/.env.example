# MongoDB Connection
# Replace with your MongoDB Atlas connection string or local MongoDB URI
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/manas?retryWrites=true&w=majority

# Server Port
PORT=5000

# JWT Secret (generate a secure random string - use: openssl rand -hex 64)
JWT_SECRET=your_jwt_secret_here

# SMTP Configuration for Email
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password_here

# Frontend URLs (for CORS)
ADMIN_URL=https://your-admin-panel.netlify.app
FRONTEND_URL=https://your-frontend.netlify.app

# Admin Email (for OTP login)
ADMIN_EMAIL=admin@manasfoundation.org

# Environment
NODE_ENV=development

# Message Encryption Secret (generate: openssl rand -hex 32)
MESSAGE_SECRET=your_encryption_secret_here

# Cloudinary Configuration (for profile photo storage)
# Sign up at https://cloudinary.com/users/register_free
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# WhatsApp Business API (Meta) - Required for WhatsApp OTP login
# Get these from Meta Developer Portal: https://developers.facebook.com/
META_WA_ACCESS_TOKEN=your_meta_whatsapp_access_token
META_WA_PHONE_NUMBER_ID=your_phone_number_id

# Firebase Configuration (for real-time chat)
# Option 1: JSON string of service account (for Vercel deployment)
FIREBASE_SERVICE_ACCOUNT={"type":"service_account","project_id":"...","private_key":"...","client_email":"..."}
# Option 2: File path (for local development) - set GOOGLE_APPLICATION_CREDENTIALS env var to the path
# GOOGLE_APPLICATION_CREDENTIALS=./firebase-service-account.json
FIREBASE_DATABASE_URL=https://your-project-id-default-rtdb.firebaseio.com
